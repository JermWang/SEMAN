# ============================================================
#  $SEMAN — environment config (TEMPLATE)
# ------------------------------------------------------------
#  Copy this file to `.env` and fill in real values:
#      cp .env.example .env
#
#  ⚠️  IMPORTANT: This site is currently a STATIC site with no
#  build step, so the browser does NOT read this file at runtime.
#  The values the live site actually uses are in app.js -> CONFIG.
#  Keep them in sync, OR add a build/serverless step that injects
#  these vars (see README). This file is the right home for real
#  SECRETS (API keys) the moment you add a serverless function —
#  e.g. exact on-chain creator-fee tracking.
#
#  `.env` is gitignored and must never be committed. This
#  `.env.example` is safe to commit (no secrets).
# ============================================================

# --- Token ---
# Your pump.fun mint (contract) address. Leave blank pre-launch.
SEMAN_CONTRACT_ADDRESS=

# --- Links ---
SEMAN_PUMP_URL=https://pump.fun/coin/
SEMAN_TWITTER_URL=https://twitter.com/
SEMAN_TELEGRAM_URL=https://t.me/
SEMAN_CHART_URL=

# --- Donation math (creator fees -> the kids) ---
SEMAN_CREATOR_FEE_RATE=0.0005      # pump.fun creator-fee share of volume (0.0005 = 0.05%)
SEMAN_PLEDGE_PERCENT=100           # % of creator fees pledged to the cause
SEMAN_RAISED_BASELINE_USD=0        # starting figure so the counter matches reality
SEMAN_GOAL_USD=100000              # fundraising goal for the progress bar
SEMAN_REFRESH_MS=30000             # how often to re-pull on-chain data (ms)
SEMAN_MANUAL_RAISED_USD=           # optional hand-set total; overrides the live estimate

# --- Secrets (only needed if/when you add a serverless backend) ---
# HELIUS_API_KEY=
# BITQUERY_API_KEY=
